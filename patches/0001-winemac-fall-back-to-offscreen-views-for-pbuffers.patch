     TRACE("hdc %p, format %d, largest %u, texture_format %#x, texture_target %#x, max_level %#x, width %d, height %d, drawable %p\n",
           hdc, format, largest, texture_format, texture_target, max_level, *width, *height, drawable);
@@ -2238,11 +2530,33 @@ static BOOL macdrv_pbuffer_create(HDC hdc, int format, BOOL largest, GLenum text
     if (!(gl = opengl_drawable_create(sizeof(*gl), &macdrv_pbuffer_funcs, format, NULL))) return FALSE;
 
     err = CGLCreatePBuffer(*width, *height, texture_target, texture_format, max_level, &gl->pbuffer);
+    if (err != kCGLNoError && (!original_texture_target || !original_texture_format))
+    {
+        for (i = 0; i < ARRAY_SIZE(attempts); i++)
+        {
+            if (attempts[i].target == texture_target && attempts[i].format == texture_format) continue;
+
+            err = CGLCreatePBuffer(*width, *height, attempts[i].target, attempts[i].format, max_level, &gl->pbuffer);
+            if (err == kCGLNoError)
+                break;
+        }
