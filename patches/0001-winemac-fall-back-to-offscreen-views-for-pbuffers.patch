@@ -2223,7 +2499,23 @@ static BOOL macdrv_pbuffer_create(HDC hdc, int format, BOOL largest, GLenum text
                                   GLint max_level, GLsizei *width, GLsizei *height, struct opengl_drawable **drawable)
 {
     struct gl_drawable *gl;
+    RECT emulated_rect;
     CGLError err;
+    const GLenum original_texture_format = texture_format;
+    const GLenum original_texture_target = texture_target;
+    unsigned int i;
+    const struct
+    {
+        GLenum target;
+        GLenum format;
+        const char *label;
+    } attempts[] =
+    {
+        { GL_TEXTURE_RECTANGLE, GL_RGB,  "default rectangle/rgb" },
+        { GL_TEXTURE_RECTANGLE, GL_RGBA, "fallback rectangle/rgba" },
+        { GL_TEXTURE_2D,        GL_RGB,  "fallback 2d/rgb" },
+        { GL_TEXTURE_2D,        GL_RGBA, "fallback 2d/rgba" },
