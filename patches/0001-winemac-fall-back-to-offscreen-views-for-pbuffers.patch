+
+static void convert_bgra_to_rgba_opaque(unsigned char *pixels, GLsizei width, GLsizei height)
+{
+    size_t total_pixels = (size_t)max(width, 1) * max(height, 1);
+    size_t i;
+
+    if (!pixels) return;
+
+    for (i = 0; i < total_pixels; ++i)
+    {
+        unsigned char *pixel = pixels + i * 4;
+        unsigned char blue = pixel[0];
+        unsigned char red = pixel[2];
+
+        pixel[0] = red;
+        pixel[2] = blue;
+        pixel[3] = 0xff;
+    }
+}
 
 
