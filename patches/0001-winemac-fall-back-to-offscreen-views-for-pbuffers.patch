+        {
+            WARN("failed to create offscreen view fallback\n");
+            opengl_drawable_release(&gl->base);
+            return FALSE;
+        }
+
+        gl->emulated_rect = emulated_rect;
+        gl->emulated_pbuffer = TRUE;
