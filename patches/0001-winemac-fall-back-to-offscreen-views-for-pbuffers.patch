+/**********************************************************************
+ *              macdrv_glCopyTexImage2D
+ *
+ * Emulate texture copies for NSView-backed pbuffer fallbacks by reading
+ * back the current surface contents and uploading them into the destination
+ * texture. This preserves the existing read/draw separation handling used
+ * by the rest of the driver.
+ */
+static void macdrv_glCopyTexImage2D(GLenum target, GLint level, GLenum internalformat,
+                                    GLint x, GLint y, GLsizei width, GLsizei height,
+                                    GLint border)
+{
+    struct macdrv_context *context = NtCurrentTeb()->glReserved2;
+    BOOL separate_readable = context && (context->read_view || context->read_pbuffer);
+    BOOL emulated_pbuffer = context && (context->draw_emulated_pbuffer || context->read_emulated_pbuffer);
+    GLenum desired_read_buffer = GL_FRONT;
+    GLint prev_read_buffer = 0;
+    GLint prev_pack_row_length = 0, prev_pack_skip_rows = 0, prev_pack_skip_pixels = 0, prev_pack_alignment = 0;
+    GLint prev_unpack_row_length = 0, prev_unpack_skip_rows = 0, prev_unpack_skip_pixels = 0, prev_unpack_alignment = 0;
+    unsigned char *pixels = NULL;
+
+    if ((separate_readable || emulated_pbuffer) && !internalformat)
+        internalformat = GL_RGBA;
+
+    if (separate_readable)
+        make_context_current(context, TRUE);
+
+    if (emulated_pbuffer)
+    {
+        if (context->emulated_pbuffer_source != GL_NONE)
+            desired_read_buffer = context->emulated_pbuffer_source;
+
+        pglGetIntegerv(GL_READ_BUFFER, &prev_read_buffer);
+        funcs->p_glFlush();
+        funcs->p_glReadBuffer(desired_read_buffer);
+
+        if ((pixels = malloc((size_t)max(width, 1) * max(height, 1) * 4)))
+        {
+            pglGetIntegerv(GL_PACK_ROW_LENGTH, &prev_pack_row_length);
+            pglGetIntegerv(GL_PACK_SKIP_ROWS, &prev_pack_skip_rows);
+            pglGetIntegerv(GL_PACK_SKIP_PIXELS, &prev_pack_skip_pixels);
+            pglGetIntegerv(GL_PACK_ALIGNMENT, &prev_pack_alignment);
+            pglGetIntegerv(GL_UNPACK_ROW_LENGTH, &prev_unpack_row_length);
+            pglGetIntegerv(GL_UNPACK_SKIP_ROWS, &prev_unpack_skip_rows);
+            pglGetIntegerv(GL_UNPACK_SKIP_PIXELS, &prev_unpack_skip_pixels);
+            pglGetIntegerv(GL_UNPACK_ALIGNMENT, &prev_unpack_alignment);
+
+            pglPixelStorei(GL_PACK_ROW_LENGTH, 0);
+            pglPixelStorei(GL_PACK_SKIP_ROWS, 0);
+            pglPixelStorei(GL_PACK_SKIP_PIXELS, 0);
+            pglPixelStorei(GL_PACK_ALIGNMENT, 4);
+            pglPixelStorei(GL_UNPACK_ROW_LENGTH, 0);
+            pglPixelStorei(GL_UNPACK_SKIP_ROWS, 0);
+            pglPixelStorei(GL_UNPACK_SKIP_PIXELS, 0);
+            pglPixelStorei(GL_UNPACK_ALIGNMENT, 4);
+
+            pglReadPixels(x, y, width, height, GL_BGRA, GL_UNSIGNED_BYTE, pixels);
+            convert_bgra_to_rgba_opaque(pixels, width, height);
+            pglTexImage2D(target, level, internalformat, width, height, border,
+                          GL_RGBA, GL_UNSIGNED_BYTE, pixels);
+
+            pglPixelStorei(GL_PACK_ROW_LENGTH, prev_pack_row_length);
+            pglPixelStorei(GL_PACK_SKIP_ROWS, prev_pack_skip_rows);
+            pglPixelStorei(GL_PACK_SKIP_PIXELS, prev_pack_skip_pixels);
+            pglPixelStorei(GL_PACK_ALIGNMENT, prev_pack_alignment);
+            pglPixelStorei(GL_UNPACK_ROW_LENGTH, prev_unpack_row_length);
+            pglPixelStorei(GL_UNPACK_SKIP_ROWS, prev_unpack_skip_rows);
+            pglPixelStorei(GL_UNPACK_SKIP_PIXELS, prev_unpack_skip_pixels);
+            pglPixelStorei(GL_UNPACK_ALIGNMENT, prev_unpack_alignment);
+            free(pixels);
+            funcs->p_glReadBuffer(prev_read_buffer);
+
+            if (separate_readable)
+                make_context_current(context, FALSE);
+            return;
+        }
+
+        funcs->p_glReadBuffer(prev_read_buffer);
+        WARN("failed to allocate emulated pbuffer copy buffer for glCopyTexImage2D\n");
+    }
+
+    pglCopyTexImage2D(target, level, internalformat, x, y, width, height, border);
+
+    if (separate_readable)
+        make_context_current(context, FALSE);
+}
+
+
+/**********************************************************************
+ *              macdrv_glCopyTexSubImage2D
+ */
+static void macdrv_glCopyTexSubImage2D(GLenum target, GLint level, GLint xoffset,
+                                       GLint yoffset, GLint x, GLint y,
+                                       GLsizei width, GLsizei height)
+{
+    struct macdrv_context *context = NtCurrentTeb()->glReserved2;
+    BOOL separate_readable = context && (context->read_view || context->read_pbuffer);
+    BOOL emulated_pbuffer = context && (context->draw_emulated_pbuffer || context->read_emulated_pbuffer);
+    GLenum desired_read_buffer = GL_FRONT;
+    GLint prev_read_buffer = 0;
+    GLint prev_pack_row_length = 0, prev_pack_skip_rows = 0, prev_pack_skip_pixels = 0, prev_pack_alignment = 0;
+    GLint prev_unpack_row_length = 0, prev_unpack_skip_rows = 0, prev_unpack_skip_pixels = 0, prev_unpack_alignment = 0;
+    unsigned char *pixels = NULL;
+
+    if (separate_readable)
+        make_context_current(context, TRUE);
+
+    if (emulated_pbuffer)
+    {
+        if (context->emulated_pbuffer_source != GL_NONE)
+            desired_read_buffer = context->emulated_pbuffer_source;
+
+        pglGetIntegerv(GL_READ_BUFFER, &prev_read_buffer);
+        funcs->p_glFlush();
+        funcs->p_glReadBuffer(desired_read_buffer);
+
+        if ((pixels = malloc((size_t)max(width, 1) * max(height, 1) * 4)))
+        {
+            pglGetIntegerv(GL_PACK_ROW_LENGTH, &prev_pack_row_length);
+            pglGetIntegerv(GL_PACK_SKIP_ROWS, &prev_pack_skip_rows);
+            pglGetIntegerv(GL_PACK_SKIP_PIXELS, &prev_pack_skip_pixels);
+            pglGetIntegerv(GL_PACK_ALIGNMENT, &prev_pack_alignment);
+            pglGetIntegerv(GL_UNPACK_ROW_LENGTH, &prev_unpack_row_length);
+            pglGetIntegerv(GL_UNPACK_SKIP_ROWS, &prev_unpack_skip_rows);
+            pglGetIntegerv(GL_UNPACK_SKIP_PIXELS, &prev_unpack_skip_pixels);
+            pglGetIntegerv(GL_UNPACK_ALIGNMENT, &prev_unpack_alignment);
+
+            pglPixelStorei(GL_PACK_ROW_LENGTH, 0);
+            pglPixelStorei(GL_PACK_SKIP_ROWS, 0);
+            pglPixelStorei(GL_PACK_SKIP_PIXELS, 0);
+            pglPixelStorei(GL_PACK_ALIGNMENT, 4);
+            pglPixelStorei(GL_UNPACK_ROW_LENGTH, 0);
+            pglPixelStorei(GL_UNPACK_SKIP_ROWS, 0);
+            pglPixelStorei(GL_UNPACK_SKIP_PIXELS, 0);
+            pglPixelStorei(GL_UNPACK_ALIGNMENT, 4);
+
+            pglReadPixels(x, y, width, height, GL_BGRA, GL_UNSIGNED_BYTE, pixels);
+            convert_bgra_to_rgba_opaque(pixels, width, height);
+            pglTexSubImage2D(target, level, xoffset, yoffset, width, height,
+                             GL_RGBA, GL_UNSIGNED_BYTE, pixels);
+
+            pglPixelStorei(GL_PACK_ROW_LENGTH, prev_pack_row_length);
+            pglPixelStorei(GL_PACK_SKIP_ROWS, prev_pack_skip_rows);
+            pglPixelStorei(GL_PACK_SKIP_PIXELS, prev_pack_skip_pixels);
+            pglPixelStorei(GL_PACK_ALIGNMENT, prev_pack_alignment);
+            pglPixelStorei(GL_UNPACK_ROW_LENGTH, prev_unpack_row_length);
+            pglPixelStorei(GL_UNPACK_SKIP_ROWS, prev_unpack_skip_rows);
+            pglPixelStorei(GL_UNPACK_SKIP_PIXELS, prev_unpack_skip_pixels);
+            pglPixelStorei(GL_UNPACK_ALIGNMENT, prev_unpack_alignment);
+            free(pixels);
+            funcs->p_glReadBuffer(prev_read_buffer);
+
+            if (separate_readable)
+                make_context_current(context, FALSE);
+            return;
+        }
+
+        funcs->p_glReadBuffer(prev_read_buffer);
+        WARN("failed to allocate emulated pbuffer copy buffer for glCopyTexSubImage2D\n");
+    }
+
+    pglCopyTexSubImage2D(target, level, xoffset, yoffset, x, y, width, height);
+
+    if (separate_readable)
+        make_context_current(context, FALSE);
+}
